#define TCOMBO(NAME, BINDINGS, OUTER_BINDINGS, INNER_BINDINGS, BOTH_BINDINGS, LEFT_KEYPOS, RIGHT_KEYPOS) \
combo_l_##NAME { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <BINDINGS>; \
	key-positions = <LEFT_KEYPOS>; \
	layers = TYP_LAYERS_LEFT; \
}; \
combo_li_##NAME { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <INNER_BINDINGS>; \
	key-positions = <LEFT_KEYPOS LIT>; \
	layers = TYP_LAYERS_LEFT; \
}; \
combo_lo_##NAME { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <OUTER_BINDINGS>; \
	key-positions = <LEFT_KEYPOS LOT>; \
	layers = TYP_LAYERS_LEFT; \
}; \
combo_lb_##NAME { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <BOTH_BINDINGS>; \
	key-positions = <LEFT_KEYPOS LIT LOT>; \
	layers = TYP_LAYERS_LEFT; \
}; \
combo_r_##NAME { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <BINDINGS>; \
	key-positions = <RIGHT_KEYPOS>; \
	layers = TYP_LAYERS_RIGHT; \
}; \
combo_ri_##NAME { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <INNER_BINDINGS>; \
	key-positions = <RIGHT_KEYPOS RIT>; \
	layers = TYP_LAYERS_RIGHT; \
}; \
combo_ro_##NAME { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <OUTER_BINDINGS>; \
	key-positions = <RIGHT_KEYPOS ROT>; \
	layers = TYP_LAYERS_RIGHT; \
}; \
combo_rb_##NAME { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <BOTH_BINDINGS>; \
	key-positions = <RIGHT_KEYPOS RIT ROT>; \
	layers = TYP_LAYERS_RIGHT; \
};

combo_l_space { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&kp SPACE>; \
	key-positions = <LOT>; \
	layers = TYP_LAYERS_LEFT; \
};

combo_r_space { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&kp SPACE>; \
	key-positions = <ROT>; \
	layers = TYP_LAYERS_RIGHT; \
};

combo_l_bspc { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&kp BSPC>; \
	key-positions = <LIT>; \
	layers = TYP_LAYERS_LEFT; \
};

combo_r_bspc { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&kp BSPC>; \
	key-positions = <RIT>; \
	layers = TYP_LAYERS_RIGHT; \
};


combo_goto_typ_l { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&totypl>; \
	key-positions = <BLR BLM TLI>; \
};
combo_goto_arw_l { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&toarwl>; \
	key-positions = <BLR TLM BLI>; \
};
combo_goto_mov_l { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&tomovl>; \
	key-positions = <TLR BLM BLI>; \
};
combo_goto_num_l { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&tonuml>; \
	key-positions = <TLR TLM BLI>; \
};
combo_goto_typ_r { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&totypr>; \
	key-positions = <BRR BRM TRI>; \
};
combo_goto_arw_r { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&toarwr>; \
	key-positions = <BRR TRM BRI>; \
};
combo_goto_mov_r { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&tomovr>; \
	key-positions = <TRR BRM TRI>; \
};
combo_goto_num_r { \
	timeout-ms = <COMBO_TIMEOUT>; \
	bindings = <&tonumr>; \
	key-positions = <TRR TRM BRI>; \
};



TCOMBO(R,        &kp R,      &kp LS(R),  &kp GT,       &kp PSCRN,      TLP,              TRP)
TCOMBO(S,        &kp S,      &kp LS(S),  &kp RBRC,     &kp C_BRI_DN,   TLR,              TRR)
TCOMBO(N,        &kp N,      &kp LS(N),  &kp RBKT,     &kp C_BRI_UP,   TLM,              TRM)
TCOMBO(I,        &kp I,      &kp LS(I),  &kp RPAR,     &kp C_PP,       TLI,              TRI)
TCOMBO(A,        &kp A,      &kp LS(A),  &kp LT,       &kp C_PREV,     BLP,              BRP)
TCOMBO(O,        &kp O,      &kp LS(O),  &kp LBRC,     &kp C_VOL_DN,   BLR,              BRR)
TCOMBO(T,        &kp T,      &kp LS(T),  &kp LBKT,     &kp C_VOL_UP,   BLM,              BRM)
TCOMBO(E,        &kp E,      &kp LS(E),  &kp LPAR,     &kp C_NEXT,     BLI,              BRI)
TCOMBO(C,        &kp C,      &kp LS(C),  &kp N1,       &kp F1,         BLR BLI,          BRR BRI)
TCOMBO(U,        &kp U,      &kp LS(U),  &kp N2,       &kp F2,         BLR BLM,          BRR BRM)
TCOMBO(Q,        &kp Q,      &kp LS(Q),  &kp N3,       &kp F3,         BLP BLM,          BRP BRM)
TCOMBO(L,        &kp L,      &kp LS(L),  &kp N4,       &kp F4,         BLP BLR,          BRP BRR)
TCOMBO(Y,        &kp Y,      &kp LS(Y),  &kp N5,       &kp F5,         TLM TLI,          TRM TRI)
TCOMBO(F,        &kp F,      &kp LS(F),  &kp N6,       &kp F6,         TLR TLI,          TRR TRI)
TCOMBO(P,        &kp P,      &kp LS(P),  &kp N7,       &kp F7,         TLR TLM,          TRR TRM)
TCOMBO(Z,        &kp Z,      &kp LS(Z),  &kp N8,       &kp F8,         TLP TLM,          TRP TRM)
TCOMBO(B,        &kp B,      &kp LS(B),  &kp N9,       &kp F9,         TLP TLR,          TRP TRR)
TCOMBO(H,        &kp H,      &kp LS(H),  &kp N0,       &kp F10,        BLM BLI,          BRM BRI)
TCOMBO(D,        &kp D,      &kp LS(D),  &kp AT,       &kp F11,        BLP BLI,          BRP BRI)
TCOMBO(G,        &kp G,      &kp LS(G),  &kp HASH,     &kp F12,        TLP TLI,          TRP TRI)
TCOMBO(X,        &kp X,      &kp LS(X),  &kp CARET,    &kp LC(X),      TLP BLM,          TRP BRM)
TCOMBO(K,        &kp K,      &kp LS(K),  &kp PLUS,     &kp LC(C),      TLI BLR,          TRI BRR)
TCOMBO(V,        &kp V,      &kp LS(V),  &kp STAR,     &kp LC(V),      TLR BLI,          TRR BRI)
TCOMBO(J,        &kp J,      &kp LS(J),  &kp EQUAL,    &kp LC(A),      TLM BLP,          TRM BRP)
TCOMBO(M,        &kp M,      &kp LS(M),  &kp DOLLAR,   &kp LC(Y),      TLP BLI,          TRP BRI)
TCOMBO(W,        &kp W,      &kp LS(W),  &kp AMPS,     &kp LC(Z),      TLI BLP,          TRI BRP)
TCOMBO(SLASH,    &kp SLASH,  &kp BSLH,   &kp PIPE,     &none,          TLR BLM,          TRR BRM)
TCOMBO(MINUS,    &kp MINUS,  &kp UNDER,  &kp TILDE,    &none,          TLM BLR,          TRM BRR)
TCOMBO(QMARK,    &kp QMARK,  &kp EXCL,   &caps_word,   &kp LC(S),      TLI BLM,          TRI BRM)
TCOMBO(COMMA,    &kp COMMA,  &kp DOT,    &kp PRCNT,    &kp LS(LC(S)),  TLM BLI,          TRM BRI)
TCOMBO(SEMI,     &kp SEMI,   &kp COLON,  &kp INS,      &none,          TLP BLR,          TRP BRR)
TCOMBO(SQT,      &kp SQT,    &kp DQT,    &kp GRAVE,    &none,          TLR BLP,          TRR BRP)
TCOMBO(TAB,      &kp TAB,    &kp DEL,    &clear_mods,  &bt BT_CLR,     TLP TLR TLM TLI,  TRP TRR TRM TRI)
TCOMBO(ENTER,    &kp ENTER,  &kp ESC,    &kp LALT,     &bootloader,    BLP BLR BLM BLI,  BRP BRR BRM BRI)
TCOMBO(LGUI,     &sk LGUI,   &kp DOWN,   &kp PGDN,     &bt BT_SEL 3,   BLP BLR BLM,      BRP BRR BRM)
TCOMBO(LALT,     &sk LALT,   &kp UP,     &kp PGUP,     &bt BT_SEL 2,   TLP TLR TLM,      TRP TRR TRM)
TCOMBO(LCTRL,    &sk LCTRL,  &kp RIGHT,  &kp END,      &bt BT_SEL 1,   BLR BLM BLI,      BRR BRM BRI)
TCOMBO(LSHIFT,   &sk LSHFT,  &kp LEFT,   &kp HOME,     &bt BT_SEL 0,   TLR TLM TLI,      TRR TRM TRI)
TCOMBO(LGUIkt,   &kt LGUI,   &kp DOWN,   &kp PGDN,     &bt BT_SEL 3,   BLP BLR BLM TLI,  BRP BRR BRM TRI)
TCOMBO(LALTkt,   &kt LALT,   &kp UP,     &kp PGUP,     &bt BT_SEL 2,   TLP TLR TLM BLI,  TRP TRR TRM BRI)
TCOMBO(LCTRLkt,  &kt LCTRL,  &kp RIGHT,  &kp END,      &bt BT_SEL 1,   TLP BLR BLM BLI,  TRP BRR BRM BRI)
TCOMBO(LSHIFTkt, &kt LSHFT,  &kp LEFT,   &kp HOME,     &bt BT_SEL 0,   BLP TLR TLM TLI,  BRP TRR TRM TRI)
